{
  "description": "iOS Dev Agent hooks — validates Swift structure, accessibility, placeholders, and logs build errors",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-project-config-edits.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-bash-safety.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-swift-structure.sh" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-no-placeholders.sh --hook" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-previews.sh --hook" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-a11y-dynamic-type.sh --hook" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-a11y-icon-buttons.sh --hook" }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/log-build-error.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/on-build-success.sh" }
        ]
      }
    ]
  }
}
